<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package Name="ci-sandbox-go" Manufacturer="Skylence" Version="$(var.Version)" UpgradeCode="A70AE8E9-24A0-41FD-BCCA-F5E8C5AC7FB7" Scope="perMachine">
    <MajorUpgrade DowngradeErrorMessage="A newer version of ci-sandbox-go is already installed." />
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="ci-sandbox-go">
        <Component Id="MainExecutable">
          <File Id="MainExe" Source="$(var.BinPath)" KeyPath="yes" />
          <Environment Id="UpdatePath" Name="PATH" Value="[INSTALLFOLDER]" Permanent="no" Part="last" Action="set" System="yes" />
        </Component>
      </Directory>
    </StandardDirectory>
  </Package>
</Wix>
